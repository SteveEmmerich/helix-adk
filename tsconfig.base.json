{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],

    // Bun runs TypeScript natively — no compilation step needed for dev.
    // For production builds we still emit .js for portability.
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    // Strict mode
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    // Interop
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": true,

    // Bun's types (replaces @types/node)
    "types": ["bun-types"],

    "skipLibCheck": true,

    "baseUrl": ".",
    "paths": {
      "@helix/*": ["packages/*/src/index.ts"],
      "@helixclaw/*": ["packages/*/src/index.ts"]
    }
  }
}
